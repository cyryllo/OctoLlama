[Unit]
Description=Ollama Manager - panel WWW
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/.local/share/ollama-manager-web
ExecStart=%h/.local/share/ollama-manager-web/.venv/bin/waitress-serve --host=0.0.0.0 --port=5000 app:app
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
